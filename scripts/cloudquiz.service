# /etc/systemd/system/curio.service
#
# Manages the Curio FastAPI application via Gunicorn + Uvicorn workers.
#
# Commands:
#   sudo systemctl start   curio
#   sudo systemctl stop    curio
#   sudo systemctl restart curio
#   sudo systemctl reload  curio       ← graceful reload (zero-downtime)
#   sudo systemctl status  curio
#   sudo journalctl -u curio -f        ← live logs

[Unit]
Description=Curio Cloud Quiz — FastAPI Application
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=notify

# Run as the ubuntu user (never root)
User=ubuntu
Group=ubuntu

# !! CRITICAL: WorkingDirectory must be the project ROOT (THE2/ equivalent)
# so that Python resolves  backend.app.*  imports correctly.
WorkingDirectory=/home/ubuntu/curio

# Load .env automatically into the process environment
EnvironmentFile=/home/ubuntu/curio/backend/.env

# Add the project root to PYTHONPATH so  backend.app.*  imports work
Environment=PYTHONPATH=/home/ubuntu/curio

# Gunicorn with Uvicorn workers
#   -w 2 → good for t3.micro (1 vCPU)
#   -w 4 → better for t3.small/medium (2 vCPU)
#
# Module path: backend.app.main:app
# (matches:  uvicorn backend.app.main:app --reload  used in development)
ExecStart=/home/ubuntu/curio/venv/bin/gunicorn backend.app.main:app \
    --worker-class uvicorn.workers.UvicornWorker \
    --workers 2 \
    --bind 127.0.0.1:8000 \
    --timeout 120 \
    --keep-alive 5 \
    --log-level info \
    --access-logfile /var/log/curio/access.log \
    --error-logfile  /var/log/curio/error.log

# Graceful reload on SIGHUP — used by  systemctl reload curio
ExecReload=/bin/kill -s HUP $MAINPID

# Restart on crash, but not on clean stop
Restart=on-failure
RestartSec=5s

# Allow large numbers of open files (needed for many concurrent connections)
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
