

#  Application 
APP_NAME="Cloud Quiz"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=production

#  PostgreSQL 
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# On EC2: HOST is usually localhost (RDS: use the RDS endpoint)
DATABASE_URL=postgresql://cloudquiz:YOUR_STRONG_DB_PASSWORD@localhost:5432/cloudquiz

# Pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

#  Security 
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_64_HEX_CHARS

ACCESS_TOKEN_EXPIRE_MINUTES=1440

#  CORS / Hosts 
# Your EC2 public IP or domain (add both http and https if using SSL)
# JSON list — keep the quotes and brackets:
FRONTEND_ORIGINS=["http://YOUR_EC2_PUBLIC_IP","https://YOUR_DOMAIN_IF_ANY"]
EC2_PUBLIC_IP=YOUR_EC2_PUBLIC_IP
